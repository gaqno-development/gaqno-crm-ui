{
  "extends": "@gaqno-development/frontcore/config/tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": "../gaqno-crm-service/gaqno-crm-ui",
    "paths": {
      "@/*": ["../gaqno-crm-service/gaqno-crm-ui/src/*"]
    },
    "jsx": "preserve",
    "skipLibCheck": true
  },
  "include": [
    "../gaqno-crm-service/gaqno-crm-ui/next-env.d.ts",
    "../gaqno-crm-service/gaqno-crm-ui/**/*.ts",
    "../gaqno-crm-service/gaqno-crm-ui/**/*.tsx",
    "../gaqno-crm-service/gaqno-crm-ui/.next/types/**/*.ts"
  ],
  "exclude": ["../gaqno-crm-service/gaqno-crm-ui/node_modules"]
}
